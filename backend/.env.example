# ============================================
# OLDKRAKEN BACKEND — Environment Variables
# ============================================

# Supabase PostgreSQL Database
# Get these from: Supabase Dashboard → Project Settings → Database → Connection string
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# JWT
JWT_SECRET=change-me-to-a-random-string
JWT_REFRESH_SECRET=change-me-to-another-random-string
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# 2FA
TWO_FA_APP_NAME=OldKraken

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SMTP_FROM_NAME=OldKraken Exchange
SMTP_FROM_EMAIL=onboarding@resend.dev

# API Keys
COINGECKO_API_URL=https://api.coingecko.com/api/v3

# Backend
BACKEND_PORT=4000
NODE_ENV=production

# Admin
ADMIN_DEFAULT_EMAIL=admin@oldkraken.com
ADMIN_DEFAULT_PASSWORD=OldKraken@Admin2024!

# Security
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
BCRYPT_ROUNDS=12

# Platform
PLATFORM_NAME=OldKraken
PLATFORM_URL=https://your-backend.vercel.app
FRONTEND_URL=https://your-frontend.vercel.app
MAINTENANCE_MODE=false
REGISTRATION_ENABLED=true
PLATFORM_ENABLED=true
