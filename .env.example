# ============================================
# OLDKRAKEN - Environment Configuration
# ============================================

# Database
DATABASE_URL=postgresql://oldkraken:oldkraken_secret@localhost:5432/oldkraken
POSTGRES_USER=oldkraken
POSTGRES_PASSWORD=oldkraken_secret
POSTGRES_DB=oldkraken

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=oldkraken_redis_secret

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# 2FA
TWO_FA_APP_NAME=OldKraken

# SMTP Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_NAME=OldKraken Exchange
SMTP_FROM_EMAIL=noreply@oldkraken.com

# API Keys
COINGECKO_API_URL=https://api.coingecko.com/api/v3

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_WS_URL=ws://localhost:4000
NEXT_PUBLIC_APP_NAME=OldKraken
NEXT_PUBLIC_DEFAULT_LOCALE=en

# Backend
BACKEND_PORT=4000
NODE_ENV=production

# Admin
ADMIN_DEFAULT_EMAIL=admin@oldkraken.com
ADMIN_DEFAULT_PASSWORD=OldKraken@Admin2024!

# Security
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
BCRYPT_ROUNDS=12

# Platform
PLATFORM_NAME=OldKraken
PLATFORM_URL=https://oldkraken.com
MAINTENANCE_MODE=false
REGISTRATION_ENABLED=true
PLATFORM_ENABLED=true
