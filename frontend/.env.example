# ============================================
# OLDKRAKEN FRONTEND — Environment Variables
# ============================================

# Backend API URL (your Vercel backend deployment)
NEXT_PUBLIC_API_URL=https://your-backend.vercel.app/api

# WebSocket URL (for live chat - same as backend without /api)
NEXT_PUBLIC_WS_URL=wss://your-backend.vercel.app

# App
NEXT_PUBLIC_APP_NAME=OldKraken
NEXT_PUBLIC_DEFAULT_LOCALE=en
